# Copy to scripts/acr.env and adjust (acr.env is gitignored if you store anything sensitive).
#
# 公网登录 / 推送（本机、非 VPC）:
ACR_REGISTRY=crpi-mpi18r3iierw5366.cn-wulanchabu.personal.cr.aliyuncs.com
#
# 在阿里云 ECS 同 VPC 内推送 / 拉取（内网，省公网流量）:
# ACR_REGISTRY=crpi-mpi18r3iierw5366-vpc.cn-wulanchabu.personal.cr.aliyuncs.com
#
# 控制台里「命名空间 / 仓库」与示例一致时为 metanote/metanote:
ACR_NAMESPACE=metanote
ACR_REPO=metanote
#
# 本地已构建的 Notex 镜像名（与 docker-compose / make notex-build 默认一致）:
NOTEX_LOCAL_IMAGE=youmind/notex:local
