# Copy to .env in the project root (same directory you run `go run` from).
# Server binaries load .env automatically; existing environment variables win.
#
# LLM Configuration
SILICONFLOW_API_KEY=sk-your-key-here
# Canonical provider env var names:
# OPENAI_API_KEY=
# OPENAI_API_BASE_URL=
# ANTHROPIC_API_KEY=
DEFAULT_LLM_MODEL=qwen/Qwen3.5-9B

# Server
PORT=8080
LOG_LEVEL=info

# After SSE disconnect, how long to keep the run (and in-flight LLM request) before cancel.
# Default 2m. Set lower (e.g. 5s) only if you need fast cleanup.
# DEERFLOW_RUN_RECONNECT_GRACE=2m

# Sandbox
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=60s

# =============================================================================
# Docker Compose (root docker-compose.yml) — infra ports and credentials
# =============================================================================
# 服务器一键启动（无 .env / config.yaml 时会从本文件与 config.example.yaml 自动生成）:
#   make docker
# 手动等价: docker compose --profile app pull --ignore-pull-failures && docker compose --profile app up -d
# Start stack: docker compose up -d
# From the host (go run ./cmd/notex), use localhost + the mapped host ports below.
#
# Port consistency (required):
#   POSTGRES_URL 里的主机端口必须等于 DB_HOST_PORT（与 compose 映射一致）。
#   MARKITDOWN_URL 的主机端口必须等于 MARKITDOWN_PORT。
# Example if you avoid conflicts with a local Postgres / other services:
#   DB_HOST_PORT=6350
#   POSTGRES_URL=postgres://postgres:postgres@localhost:6350/youmind?sslmode=disable
#   MARKITDOWN_PORT=6360
#   MARKITDOWN_URL=http://127.0.0.1:6360

MARKITDOWN_TAG=local
MARKITDOWN_PORT=8787
MARKITDOWN_ENABLE_PLUGINS=false

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=youmind
DB_HOST_PORT=5432

REDIS_HOST_PORT=6379
REDIS_PASSWORD=youmind-redis-local

WEKNORA_VERSION=local
APT_MIRROR=
DOCREADER_PORT=50051
MAX_FILE_SIZE_MB=50
MINERU_ENDPOINT=

MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin

MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091

# =============================================================================
# TTS — POST /api/tts（Studio 播客音频、LangGraph 网关；火山豆包 openspeech 单向 HTTP）
# =============================================================================
# 与本地验证命令一致：go run ./cmd/volc-tts -api-key ... -resource-id ... -voice ...
#
# VOLCENGINE_TTS_API_KEY=          # x-api-key（推荐）
# TTS_API_KEY=                     # 或与上一项二选一
# VOLCENGINE_TTS_ACCESS_TOKEN=     # 若仅设此项，会当作 x-api-key 使用（兼容旧 .env）
#
# VOLCENGINE_TTS_RESOURCE_ID=volc.service_type.10029   # 控制台资源 ID；不填时按音色推断
# VOLCENGINE_TTS_VOICE_TYPE=       # 默认 zh_male_beijingxiaoye_emo_v2_mars_bigtts
# TTS_VOICE=                       # 可与 VOLCENGINE_TTS_VOICE_TYPE 二选一
#
# VOLCENGINE_TTS_HTTP_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional

# =============================================================================
# Go apps (notex / gateway / langgraph) — wire Compose services here
# =============================================================================

# Postgres: must match DB_USER, DB_PASSWORD, DB_NAME, DB_HOST_PORT above.
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/youmind?sslmode=disable

# MarkItDown HTTP (upload + notex extraction). Should match MARKITDOWN_PORT.
MARKITDOWN_URL=http://127.0.0.1:8787

# DocReader gRPC (optional). When set, extraction tries docreader before MarkItDown / builtin.
# DOCREADER_ADDR=127.0.0.1:50051
DOCREADER_TRANSPORT=grpc
# DOCREADER_TLS=true
# DOCREADER_DIAL_TIMEOUT=15s
# DOCREADER_RPC_TIMEOUT=10m
# DOCREADER_MAX_MSG_BYTES=57671680

# Redis (optional health on GET /health when REDIS_ADDR is set).
# REDIS_ADDR=127.0.0.1:6379
# REDIS_USERNAME=
# REDIS_DB=0

# Milvus standalone HTTP health (optional). Default URL is http://127.0.0.1:${MILVUS_HEALTH_PORT}/healthz
# MILVUS_HTTP_HEALTH=http://127.0.0.1:9091/healthz
# Set to false to skip Milvus check on /health and vector-inspect metadata.
# MILVUS_HEALTH_CHECK=false
# Declares intent to use Milvus for future RAG (vector-inspect shows this flag).
# MILVUS_ADDRESS=127.0.0.1:19530
# MILVUS_COLLECTION=youmind_embeddings
# MILVUS_METRIC_TYPE=IP

# MinIO: used by the docreader container (see docker-compose.yml). Host apps do not require
# MINIO_* unless you add S3 uploads in Go. For presigned URLs from docreader, adjust
# MINIO_PUBLIC_ENDPOINT in docker-compose if not on localhost.

# =============================================================================
# Notex in Docker Compose (profiles app / dev)
# =============================================================================
# Production image: docker compose --profile app up -d   (or: make up-app)
# Dev + Air reload: docker compose --profile dev up -d notex-dev   (or: make dev-notex)
#
# Inside the notex / notex-dev containers, POSTGRES_URL and MARKITDOWN_URL are overridden
# to use compose service names (postgres:5432, markitdown:8787). Keep API keys in .env.
#
# NOTEX_HOST_PORT=8787          # host port → container 8787 (profile app)
# NOTEX_DEV_HOST_PORT=8797      # dev container (avoid clash with local go run on 8787)
# NOTEX_TAG=local               # image tag for youmind/notex（未设 NOTEX_IMAGE 时）
#
# 从阿里云 ACR 拉取预构建 Notex（ECS 上 docker login 后，见 scripts/acr-push.sh）:
# NOTEX_IMAGE=crpi-xxx-vpc.cn-wulanchabu.personal.cr.aliyuncs.com/metanote/metanote:v1.0.0
# NOTEX_DEV_IMAGE=...           # 可选；开发镜像若也推仓库再填
