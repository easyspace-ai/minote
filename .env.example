# =============================================================================
# YouMind 本地开发环境配置 (.env.example)
#
# 使用方法:
#   1. cp .env.example .env
#   2. 编辑 .env，填写 LLM API Key 等配置
#   3. make docker (启动基础服务)
#
# 说明:
#   - 此配置用于本地开发，markitdown/docreader 从 Dockerfile 构建
#   - 服务器部署请使用 .env.server.example
#
# 架构说明:
#   - docker-compose.yml         : 基础服务定义
#   - docker-compose.override.yml: 本地开发覆盖 (本地构建)
#   - docker-compose.prod.yml    : 生产部署 (ACR 镜像)
#
# 推送镜像到阿里云 ACR (本地 Mac -> 阿里云 ECS):
#   make acr-push-both ACR_VERSION=v1.0.0
#
# =============================================================================

# =============================================================================
# LLM Configuration (必填)
# =============================================================================

SILICONFLOW_API_KEY=sk-your-key-here
DEFAULT_LLM_MODEL=qwen/Qwen3.5-9B

# OpenAI 兼容配置
# OPENAI_API_KEY=
# OPENAI_API_BASE_URL=
# ANTHROPIC_API_KEY=

# =============================================================================
# Server Configuration
# =============================================================================

PORT=8080
LOG_LEVEL=info

# After SSE disconnect, how long to keep the run (and in-flight LLM request) before cancel.
# DEERFLOW_RUN_RECONNECT_GRACE=2m

# =============================================================================
# Sandbox
# =============================================================================

SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=60s

# =============================================================================
# Docker Compose 基础服务配置
#
# 本地开发使用：docker compose up -d (自动加载 override.yml 进行本地构建)
# 生产部署使用：docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
# =============================================================================

# -----------------------------------------------------------------------------
# MarkItDown HTTP (文档转换)
# -----------------------------------------------------------------------------

# 本地开发时使用 local tag
MARKITDOWN_TAG=local
MARKITDOWN_PORT=8787
MARKITDOWN_ENABLE_PLUGINS=false

# 生产环境使用 ACR 镜像 (从 acr-push.sh 输出中获取)
# MARKITDOWN_IMAGE=crpi-xxx.cn-wulanchabu.personal.cr.aliyuncs.com/metanote/markitdown:v1.0.0

# -----------------------------------------------------------------------------
# Postgres (ParadeDB)
# -----------------------------------------------------------------------------

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=youmind
DB_HOST_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

REDIS_HOST_PORT=6379
REDIS_PASSWORD=youmind-redis-local

# -----------------------------------------------------------------------------
# DocReader (gRPC 文档解析)
# -----------------------------------------------------------------------------

# 本地开发版本
WEKNORA_VERSION=local
APT_MIRROR=
DOCREADER_PORT=50051
MAX_FILE_SIZE_MB=50
MINERU_ENDPOINT=

# 生产环境使用 ACR 镜像
# DOCREADER_IMAGE=crpi-xxx.cn-wulanchabu.personal.cr.aliyuncs.com/metanote/docreader:v1.0.0

# -----------------------------------------------------------------------------
# MinIO (对象存储)
# -----------------------------------------------------------------------------

MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin

# -----------------------------------------------------------------------------
# Milvus (向量数据库)
# -----------------------------------------------------------------------------

MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091

# =============================================================================
# 应用服务连接配置 (Go apps)
#
# 注意: 以下 URL 必须与上面的端口配置一致
# =============================================================================

# Postgres 连接 (端口必须等于 DB_HOST_PORT)
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/youmind?sslmode=disable

# MarkItDown HTTP (端口必须等于 MARKITDOWN_PORT)
MARKITDOWN_URL=http://127.0.0.1:8787

# DocReader gRPC (可选，端口必须等于 DOCREADER_PORT)
# DOCREADER_ADDR=127.0.0.1:50051
DOCREADER_TRANSPORT=grpc
# DOCREADER_TLS=true
# DOCREADER_DIAL_TIMEOUT=15s
# DOCREADER_RPC_TIMEOUT=10m
# DOCREADER_MAX_MSG_BYTES=57671680

# Redis (可选，端口必须等于 REDIS_HOST_PORT)
# REDIS_ADDR=127.0.0.1:6379
# REDIS_USERNAME=
# REDIS_DB=0

# Milvus (可选)
# MILVUS_HTTP_HEALTH=http://127.0.0.1:9091/healthz
# MILVUS_HEALTH_CHECK=true
# MILVUS_ADDRESS=127.0.0.1:19530
# MILVUS_COLLECTION=youmind_embeddings
# MILVUS_METRIC_TYPE=IP

# =============================================================================
# TTS (火山引擎语音合成)
# =============================================================================

# VOLCENGINE_TTS_API_KEY=
# VOLCENGINE_TTS_ACCESS_TOKEN=
# VOLCENGINE_TTS_RESOURCE_ID=volc.service_type.10029
# VOLCENGINE_TTS_VOICE_TYPE=
# TTS_API_KEY=
# TTS_VOICE=
# VOLCENGINE_TTS_HTTP_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional

# =============================================================================
# Notex Docker 镜像 (可选，单独部署时使用)
# =============================================================================

# 构建: make notex-build -> youmind/notex:local
# 推送 ACR: 单独处理 (不在 acr-push.sh 中)
# NOTEX_IMAGE=crpi-xxx.cn-wulanchabu.personal.cr.aliyuncs.com/metanote/notex:v1.0.0
